const LAYER_NAMES = ["Foundry","Chip Designers","Cloud / Hubs","Foundation Models","Frameworks & Infra","Applications","End Users"];
const LAYER_COLORS = ["#B45309","#F59E0B","#06B6D4","#3B82F6","#A855F7","#10B981","#F43F5E"];
const EDGE_COLOR = {
  "manufactures":"#F59E0B","powers":"#F59E0B",
  "hosts":"#8B5CF6","runs":"#8B5CF6",
  "built-on":"#06B6D4",
  "integrates":"#94A3B8","routes":"#94A3B8","monitors":"#94A3B8","guards":"#94A3B8"
};

// ==== MOBILE DETECTION ====
const IS_MOBILE = window.matchMedia("(max-width: 768px)").matches || (('ontouchstart' in window) && window.innerWidth < 900);

if (IS_MOBILE) {
  renderMobile();
} else {

// ==== SETUP ====
const svg = d3.select("#canvas");
const tooltip = d3.select("#tooltip");
const container = document.getElementById("canvas-container");
let W = container.clientWidth, H = container.clientHeight;
svg.attr("width", W).attr("height", H);

const zoomG = svg.append("g").attr("class", "zoom-root");
const ringG  = zoomG.append("g").attr("class", "rings");
const hullG  = zoomG.append("g").attr("class", "hulls");
const linkG  = zoomG.append("g").attr("class", "links");
const nodeG  = zoomG.append("g").attr("class", "nodes");

const defs = svg.append("defs");
Object.entries(EDGE_COLOR).forEach(([type, color]) => {
  const safe = type.replace(/[^a-z0-9]/gi, "_");
  defs.append("marker")
    .attr("id", `arrow_${safe}`)
    .attr("viewBox", "0 -5 10 10").attr("refX", 10).attr("refY", 0)
    .attr("markerUnits", "userSpaceOnUse")
    .attr("markerWidth", 14).attr("markerHeight", 14)
    .attr("orient", "auto")
    .append("path").attr("d", "M0,-5L10,0L0,5").attr("fill", color).attr("opacity", 0.85);
});

const zoomBehavior = d3.zoom().scaleExtent([0.15, 6]).on("zoom", ev => {
  zoomG.attr("transform", ev.transform);
});
svg.call(zoomBehavior);

// ==== STATE ====
let radialMode = true;
let popThreshold = IS_MOBILE ? 75 : 60;
let linkWeightThreshold = 1;
let activeCat = "all";
let searchTerm = "";
let activeTypes = new Set(["manufactures","powers","hosts","runs","built-on","integrates","routes","monitors","guards"]);
let selection = null;
let selectedArrowId = null;

const SIM_NODES = NODES.slice();

// ==== BUBBLES ====
const BUBBLE_COLORS = {
  "Coding":"#3B82F6","Productivity":"#8B5CF6","Design":"#EC4899",
  "Automation":"#F59E0B","Research":"#06B6D4","Image Gen":"#EF4444",
  "Video Gen":"#F97316","Avatar & Voice":"#A78BFA","Music Gen":"#10B981",
  "Speech & STT":"#14B8A6","Agents":"#6366F1","Robotics":"#94A3B8",
  "Vibe Coding":"#22D3EE","Chat":"#60A5FA","Legal AI":"#D4A373",
  "Healthcare AI":"#06D6A0","3D Gen":"#BB86FC","OS Assistants":"#F472B6",
  "Agent Frameworks":"#A855F7","Local Inference":"#C084FC","LLM Routing":"#F0ABFC",
  "Vector DBs":"#D8B4FE","Observability":"#E9D5FF","Data & Eval":"#DDD6FE",
  "Web Data":"#C4B5FD","AI Safety":"#FCA5A5",
  "Frontier LLMs":"#3B82F6","Open Weight Models":"#60A5FA","Foundation Media":"#7DD3FC",
  "Cloud Platforms":"#06B6D4","Model Hub":"#22D3EE",
  "GPU Makers":"#F59E0B","Cloud Silicon":"#FBBF24","Edge AI":"#FCD34D","ASIC":"#FDE68A",
  "Foundries":"#B45309","Leading Foundries":"#B45309","US Foundries":"#B45309","Chinese Foundries":"#B45309"
};

function bubbleKeyFor(n) {
  if (n.layer === 1) return n.subCat;
  if (n.layer === 0) return n.category;
  return n.category;
}

const BUBBLE_GROUPS = {};
SIM_NODES.forEach(n => {
  if (n.layer < 1 || n.layer > 5) return;
  const key = bubbleKeyFor(n);
  const id = `${n.layer}:${key}`;
  if (!BUBBLE_GROUPS[id]) {
    BUBBLE_GROUPS[id] = {
      id, bubId: `bub:${id}`, layer: n.layer, key,
      label: key, color: BUBBLE_COLORS[key] || LAYER_COLORS[n.layer] || "#64748B",
      memberIds: []
    };
  }
  BUBBLE_GROUPS[id].memberIds.push(n.id);
});
const ALL_BUBBLES = Object.values(BUBBLE_GROUPS);

function isBubbleRef(s) { return typeof s === "string" && s.startsWith("bub:"); }
function bubbleRefToId(s) { return s.replace(/^bub:/, ""); }

let arrowIdCounter = 0;
const LINKS = LINKS_RAW.map(([s, t, type, w, name]) => ({
  arrowId: `arrow_${arrowIdCounter++}`,
  sourceRef: s, targetRef: t,
  sourceIsBubble: isBubbleRef(s),
  targetIsBubble: isBubbleRef(t),
  type, weight: w,
  name: name || autoName(type, s, t)
}));

function autoName(type, s, t) {
  const tN = isBubbleRef(t) ? bubbleRefToId(t).split(":")[1] : (NODES.find(n => n.id === t)?.name || t);
  const sN = isBubbleRef(s) ? bubbleRefToId(s).split(":")[1] : (NODES.find(n => n.id === s)?.name || s);
  switch(type) {
    case "manufactures": return `${sN} fabricates ${tN}`;
    case "powers": return `${sN} powers ${tN}`;
    case "hosts": return `${sN} hosts ${tN}`;
    case "runs": return `${sN} runs ${tN}`;
    case "built-on": return `${sN} built on ${tN}`;
    case "integrates": return `${sN} integrates with ${tN}`;
    case "routes": return `${sN} routes to ${tN}`;
    case "monitors": return `${sN} monitors ${tN}`;
    case "guards": return `${sN} guards ${tN}`;
    default: return `${sN} ↔ ${tN}`;
  }
}

// ==== RADIAL LAYOUT ====
// v4: L5 gets a bigger annulus; inner layers compressed slightly so outer ring has breathing room.
const RING_FRACTIONS = [
  [0.000, 0.090],  // L0
  [0.090, 0.185],  // L1
  [0.185, 0.280],  // L2
  [0.280, 0.430],  // L3
  [0.430, 0.580],  // L4
  [0.580, 1.000],  // L5 (wider)
];

function getR() { return Math.min(W, H) * 0.48; } // v4: slightly larger usable radius
function getRadii(layer) {
  const R = getR();
  const [f0, f1] = RING_FRACTIONS[layer] || [0, 0.1];
  return { inner: R * f0, outer: R * f1, mid: R * (f0 + f1) / 2 };
}

const layerCategoryInfo = {};

function precomputeAngles() {
  for (let layer = 1; layer <= 5; layer++) {
    const layerNodes = SIM_NODES.filter(n => n.layer === layer);
    if (!layerNodes.length) continue;

    const cats = [];
    layerNodes.forEach(n => { if (!cats.includes(n.category)) cats.push(n.category); });

    const totalNodes = layerNodes.length;
    const numCats = cats.length;
    // v4: wider gap so bubbles in same ring don't touch
    const gapPerSector = numCats > 1 ? (layer === 5 ? 0.10 : 0.08) : 0;
    const totalGap = gapPerSector * numCats;
    const availableAngle = 2 * Math.PI - totalGap;

    let currentAngle = -Math.PI / 2;
    const catInfo = [];

    cats.forEach(cat => {
      const catNodes = layerNodes.filter(n => n.category === cat);
      // minimum span so small categories still get visible room
      const rawSpan = availableAngle * (catNodes.length / totalNodes);
      const minSpan = layer === 5 ? 0.13 : 0.10;
      const span = Math.max(rawSpan, minSpan);
      const endAngle = currentAngle + span;
      const midAngle = currentAngle + span / 2;

      catInfo.push({ category: cat, nodes: catNodes, startAngle: currentAngle, endAngle, midAngle });

      catNodes.forEach((n, i) => {
        const count = catNodes.length;
        if (count === 1) n._targetAngle = midAngle;
        else {
          const pad = span * 0.1;
          n._targetAngle = currentAngle + pad + (i / (count - 1)) * (span - 2 * pad);
        }
      });

      currentAngle = endAngle + gapPerSector;
    });
    layerCategoryInfo[layer] = catInfo;
  }
}
precomputeAngles();

// ==== DRAW RINGS ====
function drawRingBackgrounds() {
  ringG.selectAll("*").remove();
  defs.selectAll("[id^='arc_label_']").remove();
  const cx = W / 2, cy = H / 2;

  const l0 = getRadii(0);
  const g0 = ringG.append("g").attr("class", "ring ring-0");
  g0.append("circle")
    .attr("cx", cx).attr("cy", cy).attr("r", l0.outer)
    .attr("fill", LAYER_COLORS[0] + "22").attr("stroke", LAYER_COLORS[0] + "60").attr("stroke-width", 1.5);
  g0.append("text")
    .attr("class", "ring-label").attr("data-layer", 0)
    .attr("x", cx).attr("y", cy - l0.outer + 12)
    .attr("text-anchor", "middle").attr("dominant-baseline", "auto")
    .attr("font-size", "9px").attr("fill", LAYER_COLORS[0])
    .text(LAYER_NAMES[0]);

  for (let layer = 1; layer <= 5; layer++) {
    const { inner, outer } = getRadii(layer);
    const color = LAYER_COLORS[layer];
    const g = ringG.append("g").attr("class", `ring ring-${layer}`);

    if (layer === 5) {
      g.append("circle")
        .attr("cx", cx).attr("cy", cy).attr("r", outer)
        .attr("fill", "none").attr("stroke", color + "22")
        .attr("stroke-width", 1).attr("stroke-dasharray", "6,4");
      g.append("circle")
        .attr("cx", cx).attr("cy", cy).attr("r", inner)
        .attr("fill", "none").attr("stroke", color + "22")
        .attr("stroke-width", 1).attr("stroke-dasharray", "3,4");
    } else {
      const fullArc = d3.arc().innerRadius(inner).outerRadius(outer).startAngle(0).endAngle(2 * Math.PI);
      g.append("path").attr("d", fullArc).attr("transform", `translate(${cx},${cy})`)
        .attr("fill", color + "18").attr("stroke", color + "50").attr("stroke-width", 1.5);
    }

    // Ring label INSIDE ring near top edge
    const labelY = cy - outer + 14;
    g.append("text")
      .attr("class", "ring-label").attr("data-layer", layer)
      .attr("x", cx).attr("y", labelY)
      .attr("text-anchor", "middle").attr("dominant-baseline", "auto")
      .attr("font-size", layer === 5 ? "11px" : "10px")
      .attr("fill", color)
      .text(LAYER_NAMES[layer])
      .on("click", (ev) => { ev.stopPropagation(); selectLayer(layer); });
  }

  ringG.selectAll("text.ring-label").on("click", function(ev) {
    ev.stopPropagation();
    const l = +d3.select(this).attr("data-layer");
    selectLayer(l);
  });
}
drawRingBackgrounds();

// ==== LAYER 0 PLACEMENT ====
function placeL0() {
  const l0Nodes = SIM_NODES.filter(n => n.layer === 0);
  const tsmc = l0Nodes.find(n => n.id === "TSMC");
  const others = l0Nodes.filter(n => n.id !== "TSMC");
  const cx = W / 2, cy = H / 2;
  const { outer } = getRadii(0);
  if (tsmc) { tsmc._targetAngle = 0; tsmc._isCenter = true; }
  others.forEach((n, i) => {
    const ang = -Math.PI / 2 + (i / others.length) * 2 * Math.PI;
    n._targetAngle = ang;
    n._l0Radius = outer * 0.55;
  });
}
placeL0();

function layerX(layer) { const pad = 60; return pad + (W - 2 * pad) * (layer / 5); }
const layerCatOrder = {};
SIM_NODES.forEach(n => {
  if (!layerCatOrder[n.layer]) layerCatOrder[n.layer] = [];
  if (!layerCatOrder[n.layer].includes(n.category)) layerCatOrder[n.layer].push(n.category);
});
function categoryY(n) {
  const cats = layerCatOrder[n.layer] || [];
  const idx = cats.indexOf(n.category);
  const total = cats.length;
  if (total <= 1) return H / 2;
  return 90 + (H - 150) * (idx / (total - 1));
}

function nodeRadius(n) {
  const base = IS_MOBILE ? 9 : 7;
  const scale = IS_MOBILE ? 11 : 9;
  return base + (n.pop / 100) * scale;
}

// ==== BUBBLES DRAW ====
const curveGen = d3.line().curve(d3.curveCatmullRomClosed.alpha(0.5));

function getBubblePath(memberIds, padding) {
  if (padding === undefined) padding = 24;
  const pts = SIM_NODES.filter(n => memberIds.includes(n.id) && isVisible(n) && n.x !== undefined).map(n => [n.x, n.y]);
  if (!pts.length) return null;
  if (pts.length === 1) {
    const px = pts[0][0], py = pts[0][1], r = padding + 14;
    return `M${px - r},${py} A${r},${r} 0 1,0 ${px + r},${py} A${r},${r} 0 1,0 ${px - r},${py}`;
  }
  if (pts.length === 2) {
    const mx = (pts[0][0] + pts[1][0]) / 2, my = (pts[0][1] + pts[1][1]) / 2;
    pts.push([mx + (pts[1][1] - pts[0][1]) * 0.5, my - (pts[1][0] - pts[0][0]) * 0.5]);
  }
  const hull = d3.polygonHull(pts);
  if (!hull) return null;
  const hcx = hull.reduce((s, p) => s + p[0], 0) / hull.length;
  const hcy = hull.reduce((s, p) => s + p[1], 0) / hull.length;
  const padded = hull.map(([hx, hy]) => {
    const dx = hx - hcx, dy = hy - hcy, len = Math.sqrt(dx * dx + dy * dy) || 1;
    return [hx + dx / len * padding, hy + dy / len * padding];
  });
  return curveGen(padded);
}

function bubbleCentroid(bubId) {
  const grp = BUBBLE_GROUPS[bubId];
  if (!grp) return null;
  const members = SIM_NODES.filter(n => grp.memberIds.includes(n.id) && n.x !== undefined);
  if (!members.length) return null;
  const cx = members.reduce((s, n) => s + n.x, 0) / members.length;
  // Pin endpoint to the bubble label (topmost member y - 14)
  const cy = Math.min(...members.map(n => n.y)) - 14;
  return { x: cx, y: cy, r: 8 };
}

function bubbleDrag(grp) {
  let ox, oy, startPos;
  return d3.drag()
    .on("start", (ev) => {
      if (!ev.active) sim.alphaTarget(0.3).restart();
      ox = ev.x; oy = ev.y;
      startPos = SIM_NODES.filter(n => grp.memberIds.includes(n.id)).map(n => ({ node: n, x: n.x, y: n.y }));
      startPos.forEach(({ node }) => { node.fx = node.x; node.fy = node.y; });
    })
    .on("drag", (ev) => {
      const dx = ev.x - ox, dy = ev.y - oy;
      startPos.forEach(({ node, x, y }) => { node.fx = x + dx; node.fy = y + dy; });
    })
    .on("end", (ev) => {
      if (!ev.active) sim.alphaTarget(0);
      startPos.forEach(({ node }) => { node.fx = null; node.fy = null; });
    });
}

function redrawBubbles() {
  if (!radialMode) { hullG.selectAll("*").remove(); return; }
  const bubbleData = ALL_BUBBLES
    .filter(b => b.layer >= 1 && b.layer <= 5)
    .map(grp => {
      const members = SIM_NODES.filter(n => grp.memberIds.includes(n.id) && isVisible(n));
      return { ...grp, members, path: getBubblePath(grp.memberIds, grp.layer === 5 ? 22 : 14) };
    })
    .filter(d => d.path && d.members.length > 0);

  const sel = hullG.selectAll("path.bubble-hull").data(bubbleData, d => d.id);
  sel.join(
    enter => enter.append("path").attr("class", "bubble-hull")
      .attr("fill-opacity", 0.1).attr("stroke-width", 1.5)
      .attr("stroke-dasharray", "5,3")
      .each(function(d) { d3.select(this).call(bubbleDrag(d)); })
      .on("click", (ev, d) => { ev.stopPropagation(); selectBubble(d.id); }),
    update => update,
    exit => exit.remove()
  )
  .attr("d", d => d.path)
  .attr("fill", d => d.color)
  .attr("stroke", d => d.color + "99");

  hullG.selectAll("text.bubble-label").data(bubbleData, d => d.id)
    .join("text").attr("class", "bubble-label")
    .attr("text-anchor", "middle").attr("font-size", d => d.layer === 5 ? "10px" : "9px")
    .attr("font-weight", "700").attr("pointer-events", "all")
    .attr("fill", d => d.color)
    .attr("x", d => d.members.reduce((s, n) => s + n.x, 0) / d.members.length)
    .attr("y", d => Math.min(...d.members.map(n => n.y)) - 14)
    .text(d => d.label)
    .on("click", (ev, d) => { ev.stopPropagation(); selectBubble(d.id); });

  applyHighlights();
}

// ==== FORCES ====
function forceAngular() {
  function force(alpha) {
    const cx = W / 2, cy = H / 2;
    SIM_NODES.forEach(n => {
      if (n.layer === 0) return;
      if (n._targetAngle === undefined) return;
      const dx = n.x - cx, dy = n.y - cy;
      const r = Math.sqrt(dx * dx + dy * dy) || 0.001;
      const curAngle = Math.atan2(dy, dx);
      let diff = n._targetAngle - curAngle;
      while (diff > Math.PI) diff -= 2 * Math.PI;
      while (diff < -Math.PI) diff += 2 * Math.PI;
      const tx = -dy / r, ty = dx / r;
      // v4: stronger angular pull on L5 to keep categories in their sector
      const mult = n.layer === 5 ? 14 : 22;
      const f = diff * 0.85 * alpha * mult;
      n.vx += tx * f; n.vy += ty * f;
    });
  }
  return force;
}

function forceL0() {
  function force(alpha) {
    const cx = W / 2, cy = H / 2;
    SIM_NODES.filter(n => n.layer === 0).forEach(n => {
      let tx, ty;
      if (n.id === "TSMC") { tx = cx; ty = cy; }
      else {
        const r = n._l0Radius || getRadii(0).outer * 0.55;
        tx = cx + r * Math.cos(n._targetAngle);
        ty = cy + r * Math.sin(n._targetAngle);
      }
      n.vx += (tx - n.x) * 0.25 * alpha * 4;
      n.vy += (ty - n.y) * 0.25 * alpha * 4;
    });
  }
  return force;
}

function initRadialPositions() {
  const cx = W / 2, cy = H / 2;
  SIM_NODES.forEach(n => {
    if (n.layer === 0) {
      if (n.id === "TSMC") { n.x = cx; n.y = cy; }
      else {
        const r = n._l0Radius || getRadii(0).outer * 0.55;
        n.x = cx + r * Math.cos(n._targetAngle || 0);
        n.y = cy + r * Math.sin(n._targetAngle || 0);
      }
    } else {
      const { mid } = getRadii(n.layer);
      const a = n._targetAngle !== undefined ? n._targetAngle : 0;
      n.x = cx + mid * Math.cos(a) + (Math.random() - 0.5) * 3;
      n.y = cy + mid * Math.sin(a) + (Math.random() - 0.5) * 3;
    }
    n.vx = n.vy = 0;
  });
}
initRadialPositions();

const CLUSTER_LINKS = [];
ALL_BUBBLES.forEach(grp => {
  for (let i = 0; i < grp.memberIds.length - 1; i++) {
    CLUSTER_LINKS.push({ source: grp.memberIds[i], target: grp.memberIds[i + 1], type: "_cluster", weight: 0 });
  }
});

const SIM_NODE_LINKS = LINKS
  .filter(l => !l.sourceIsBubble && !l.targetIsBubble)
  .map(l => ({ source: l.sourceRef, target: l.targetRef, type: l.type, weight: l.weight }));

const ALL_SIM_LINKS = [...SIM_NODE_LINKS, ...CLUSTER_LINKS];

// v4: bigger collision radius so nodes don't merge
const sim = d3.forceSimulation(SIM_NODES)
  .force("link", d3.forceLink(ALL_SIM_LINKS).id(d => d.id)
    .distance(d => d.type === "_cluster" ? 48 : 80)
    .strength(d => d.type === "_cluster" ? 0.12 : 0.015))
  .force("radial", d3.forceRadial(n => n.layer === 0 ? 0 : getRadii(n.layer).mid, W / 2, H / 2)
    .strength(n => n.layer === 0 ? 0 : (n.layer === 5 ? 0.25 : 0.9)))
  .force("angular", forceAngular())
  .force("l0", forceL0())
  .force("collision", d3.forceCollide().radius(d => nodeRadius(d) + 11).strength(0.95))
  .force("charge", d3.forceManyBody().strength(d => d.layer === 5 ? -45 : -18));

sim.on("tick", ticked);

// ==== LINKS ====
const link = linkG.selectAll("path.link")
  .data(LINKS, d => d.arrowId).join("path")
  .attr("class", "link")
  .attr("data-arrow-id", d => d.arrowId)
  .attr("stroke", d => EDGE_COLOR[d.type] || "#94A3B8")
  .attr("stroke-width", d => 0.7 + (d.weight - 1) * 0.35)
  .attr("marker-end", d => `url(#arrow_${(d.type||"").replace(/[^a-z0-9]/gi,"_")})`)
  .style("cursor", "pointer")
  .on("click", (ev, d) => { ev.stopPropagation(); selectArrow(d, ev); })
  .on("mouseover", (ev, d) => {
    tooltip.style("display", "block").html(
      `<div class="tt-conn-name">${d.name}</div>
       <div class="tt-conn-type">${d.type} · weight ${d.weight}</div>`
    );
  })
  .on("mousemove", (ev) => tooltip.style("left", (ev.clientX + 14) + "px").style("top", (ev.clientY + 14) + "px"))
  .on("mouseout", () => tooltip.style("display", "none"));

// ==== NODES ====
const node = nodeG.selectAll("g.node")
  .data(SIM_NODES, d => d.id)
  .join("g").attr("class", "node")
  .call(d3.drag()
    .on("start", (ev, d) => { if (!ev.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
    .on("drag",  (ev, d) => { d.fx = ev.x; d.fy = ev.y; })
    .on("end",   (ev, d) => { if (!ev.active) sim.alphaTarget(0); d.fx = null; d.fy = null; }))
  .on("mouseover", onHover)
  .on("mouseout", onUnhover)
  .on("mousemove", onMove);

node.append("circle")
  .attr("class", "node-circle")
  .attr("r", d => nodeRadius(d))
  .attr("fill", "#ffffff")
  .attr("stroke", d => LAYER_COLORS[d.layer] || "#475569")
  .attr("stroke-width", 2);

function initials(name) {
  const p = name.split(/[\s\-]+/).filter(Boolean);
  return p.length === 1 ? p[0].slice(0, 2).toUpperCase() : (p[0][0] + p[1][0]).toUpperCase();
}

node.each(function(d) {
  if (d.domain || d.imgUrl) {
    const clipId = "clip_" + d.id.replace(/[^a-z0-9]/gi, "_");
    defs.append("clipPath").attr("id", clipId).append("circle").attr("r", nodeRadius(d) - 2);
    const imgSrc = d.imgUrl || `https://www.google.com/s2/favicons?domain=${d.domain}&sz=256`;
    const img = d3.select(this).append("image")
      .attr("href", imgSrc)
      .attr("x", -(nodeRadius(d) - 2)).attr("y", -(nodeRadius(d) - 2))
      .attr("width", (nodeRadius(d) - 2) * 2).attr("height", (nodeRadius(d) - 2) * 2)
      .attr("clip-path", `url(#${clipId})`).attr("preserveAspectRatio", "xMidYMid slice");
    img.on("error", function() {
      // fallback chain: try google favicon of domain, then initials
      const me = d3.select(this);
      if (d.domain && me.attr("href") !== `https://www.google.com/s2/favicons?domain=${d.domain}&sz=256`) {
        me.attr("href", `https://www.google.com/s2/favicons?domain=${d.domain}&sz=256`);
        return;
      }
      me.remove();
      d3.select(this.parentNode).append("text")
        .attr("text-anchor", "middle").attr("dy", "0.35em")
        .attr("font-size", nodeRadius(d) * 0.55).attr("fill", "#1E293B")
        .attr("font-weight", 700).attr("pointer-events", "none").text(initials(d.name));
    });
  } else {
    d3.select(this).append("text")
      .attr("text-anchor", "middle").attr("dy", "0.35em")
      .attr("font-size", nodeRadius(d) * 0.55).attr("fill", "#1E293B")
      .attr("font-weight", 700).attr("pointer-events", "none").text(initials(d.name));
  }
});

nodeG.selectAll("g.node").append("text")
  .attr("class", "label")
  .attr("dy", d => nodeRadius(d) + 11)
  .text(d => d.name);

function getEndpoint(ref, isBubble) {
  if (isBubble) {
    const bid = bubbleRefToId(ref);
    const c = bubbleCentroid(bid);
    if (c) return { x: c.x, y: c.y, r: c.r, isBubble: true };
    return null;
  }
  const n = typeof ref === "object" ? ref : SIM_NODES.find(x => x.id === ref);
  if (!n || n.x === undefined) return null;
  return { x: n.x, y: n.y, r: nodeRadius(n) + 4, isBubble: false };
}

function ticked() {
  const cx = W / 2, cy = H / 2;
  link.attr("d", d => {
    const s = getEndpoint(d.sourceRef, d.sourceIsBubble);
    const t = getEndpoint(d.targetRef, d.targetIsBubble);
    if (!s || !t) return null;
    const dx = t.x - s.x, dy = t.y - s.y, len = Math.sqrt(dx * dx + dy * dy) || 1;
    const sx = s.x + (dx/len) * s.r, sy = s.y + (dy/len) * s.r;
    const ex = t.x - (dx/len) * t.r, ey = t.y - (dy/len) * t.r;
    const mx = (sx + ex) / 2, my = (sy + ey) / 2;
    const pull = 0.18;
    const qx = mx + (cx - mx) * pull, qy = my + (cy - my) * pull;
    return `M${sx},${sy}Q${qx},${qy} ${ex},${ey}`;
  });
  node.attr("transform", d => `translate(${d.x},${d.y})`);
  redrawBubbles();
}

// ==== INTERACTIONS ====
function nodeNeighbors(id) {
  const s = new Set([id]);
  LINKS.forEach(l => {
    if (l.sourceIsBubble || l.targetIsBubble) return;
    if (l.sourceRef === id) s.add(l.targetRef);
    if (l.targetRef === id) s.add(l.sourceRef);
  });
  return s;
}

function onHover(ev, d) {
  if (selection) return;
  const nb = nodeNeighbors(d.id);
  node.classed("dim", n => !nb.has(n.id));
  link.classed("highlight", l => !l.sourceIsBubble && !l.targetIsBubble && (l.sourceRef === d.id || l.targetRef === d.id))
      .classed("dim", l => {
        if (l.sourceIsBubble || l.targetIsBubble) return true;
        return l.sourceRef !== d.id && l.targetRef !== d.id;
      });
  tooltip.style("display", "block").html(
    `<div class="tt-name">${d.name}</div>
     <div class="tt-cats">${d.superCat} &middot; ${d.category} &middot; ${d.subCat}</div>
     <div class="tt-desc">${d.desc}</div>
     <div class="tt-meta"><span class="tt-pop">Popularity ${d.pop}</span><span>Ring: ${LAYER_NAMES[d.layer]}</span></div>`
  );
}
function onUnhover() {
  if (!selection) applyHighlights();
  tooltip.style("display", "none");
}
function onMove(ev) {
  tooltip.style("left", (ev.clientX + 14) + "px").style("top", (ev.clientY + 14) + "px");
}

function selectNode(d) {
  selection = { kind: "node", id: d.id };
  selectedArrowId = null;
  openSidePanel(d);
  applyHighlights();
}
function selectBubble(bubId) {
  selection = { kind: "bubble", id: bubId };
  selectedArrowId = null;
  openBubblePanel(bubId);
  applyHighlights();
}
function selectLayer(layer) {
  selection = { kind: "layer", id: `L${layer}`, layer };
  selectedArrowId = null;
  closeSidePanel();
  applyHighlights();
}
function clearSelection() {
  selection = null;
  selectedArrowId = null;
  closeSidePanel();
  applyHighlights();
}
function selectArrow(l, ev) {
  selectedArrowId = l.arrowId;
  link.classed("selected-arrow", x => x.arrowId === l.arrowId);
  tooltip.style("display", "block")
    .style("left", (ev.clientX + 14) + "px").style("top", (ev.clientY + 14) + "px")
    .html(`<div class="tt-conn-name">${l.name}</div>
           <div class="tt-conn-type">${l.type} · weight ${l.weight}</div>
           <div class="tt-desc" style="margin-top:6px">${l.sourceIsBubble ? "📦 " : ""}${refLabel(l.sourceRef)} → ${l.targetIsBubble ? "📦 " : ""}${refLabel(l.targetRef)}</div>`);
}

function refLabel(ref) {
  if (isBubbleRef(ref)) {
    const key = bubbleRefToId(ref).split(":").slice(1).join(":");
    return key + " (bubble)";
  }
  return NODES.find(n => n.id === ref)?.name || ref;
}

function applyHighlights() {
  if (!selection) {
    node.classed("dim", n => !isVisible(n));
    link.classed("highlight", false).classed("dim", l => !isLinkVisible(l));
    hullG.selectAll("path.bubble-hull").classed("bubble-dim", false).classed("bubble-selected", false);
    link.classed("selected-arrow", l => l.arrowId === selectedArrowId);
    return;
  }

  if (selection.kind === "layer") {
    const L = selection.layer;
    node.classed("dim", n => n.layer !== L);
    link.classed("highlight", false).classed("dim", true);
    hullG.selectAll("path.bubble-hull").classed("bubble-dim", d => d.layer !== L).classed("bubble-selected", false);
  } else if (selection.kind === "node") {
    const id = selection.id;
    const nb = new Set([id]);
    LINKS.forEach(l => {
      if (l.sourceIsBubble || l.targetIsBubble) return;
      if (l.sourceRef === id) nb.add(l.targetRef);
      if (l.targetRef === id) nb.add(l.sourceRef);
    });
    node.classed("dim", n => !nb.has(n.id));
    link.classed("highlight", l => !l.sourceIsBubble && !l.targetIsBubble && (l.sourceRef === id || l.targetRef === id))
        .classed("dim", l => {
          if (l.sourceIsBubble || l.targetIsBubble) return true;
          return l.sourceRef !== id && l.targetRef !== id;
        });
    hullG.selectAll("path.bubble-hull").classed("bubble-dim", true).classed("bubble-selected", false);
  } else if (selection.kind === "bubble") {
    const bubId = selection.id;
    const grp = BUBBLE_GROUPS[bubId];
    const bubRef = `bub:${bubId}`;
    const memberSet = new Set(grp ? grp.memberIds : []);
    node.classed("dim", n => !memberSet.has(n.id));
    link.classed("highlight", l => l.sourceRef === bubRef || l.targetRef === bubRef)
        .classed("dim", l => l.sourceRef !== bubRef && l.targetRef !== bubRef);
    hullG.selectAll("path.bubble-hull")
      .classed("bubble-selected", d => d.id === bubId)
      .classed("bubble-dim", d => d.id !== bubId);
  }
  link.classed("selected-arrow", l => l.arrowId === selectedArrowId);
}

function isVisible(n) {
  if (n.pop < popThreshold) return false;
  if (activeCat !== "all" && n.superCat !== activeCat) return false;
  if (searchTerm && !n.name.toLowerCase().includes(searchTerm) && !n.id.toLowerCase().includes(searchTerm)) return false;
  return true;
}
function isLinkVisible(l) {
  if (l.weight < linkWeightThreshold) return false;
  if (!activeTypes.has(l.type)) return false;
  if (!l.sourceIsBubble) {
    const s = SIM_NODES.find(n => n.id === l.sourceRef);
    if (!s || !isVisible(s)) return false;
  } else {
    const grp = BUBBLE_GROUPS[bubbleRefToId(l.sourceRef)];
    if (!grp || !grp.memberIds.some(id => { const n = SIM_NODES.find(x => x.id === id); return n && isVisible(n); })) return false;
  }
  if (!l.targetIsBubble) {
    const t = SIM_NODES.find(n => n.id === l.targetRef);
    if (!t || !isVisible(t)) return false;
  } else {
    const grp = BUBBLE_GROUPS[bubbleRefToId(l.targetRef)];
    if (!grp || !grp.memberIds.some(id => { const n = SIM_NODES.find(x => x.id === id); return n && isVisible(n); })) return false;
  }
  return true;
}
function applyFilters() {
  node.style("display", n => isVisible(n) ? null : "none");
  link.style("display", l => isLinkVisible(l) ? null : "none");
  const shown = SIM_NODES.filter(isVisible).length;
  const shownLinks = LINKS.filter(isLinkVisible).length;
  document.getElementById("stats").textContent = `${shown} nodes / ${shownLinks} links`;
  redrawBubbles();
}

// ==== UI ====
document.getElementById("pop-slider").addEventListener("input", e => {
  popThreshold = +e.target.value;
  document.getElementById("pop-value").textContent = popThreshold;
  applyFilters();
});
const linkSlider = document.getElementById("link-slider");
linkSlider.style.accentColor = "#A78BFA";
linkSlider.addEventListener("input", e => {
  linkWeightThreshold = +e.target.value;
  document.getElementById("link-value").textContent = linkWeightThreshold;
  applyFilters();
});
document.querySelectorAll(".filter-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".filter-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    activeCat = btn.dataset.cat;
    applyFilters();
  });
});
document.getElementById("search").addEventListener("input", e => {
  searchTerm = e.target.value.trim().toLowerCase();
  applyFilters();
});
document.getElementById("clear-btn").addEventListener("click", clearSelection);

const layoutBtn = document.getElementById("layout-toggle");
layoutBtn.addEventListener("click", () => {
  radialMode = !radialMode;
  layoutBtn.textContent = radialMode ? "View: Radial" : "View: Force";
  if (radialMode) {
    sim.force("radial", d3.forceRadial(n => n.layer === 0 ? 0 : getRadii(n.layer).mid, W / 2, H / 2)
        .strength(n => n.layer === 0 ? 0 : (n.layer === 5 ? 0.25 : 0.9)))
       .force("angular", forceAngular())
       .force("l0", forceL0())
       .force("x", null).force("y", null);
    ringG.style("display", null);
    initRadialPositions();
  } else {
    sim.force("radial", null).force("angular", null).force("l0", null)
       .force("x", d3.forceX(d => layerX(d.layer)).strength(0.92))
       .force("y", d3.forceY(d => categoryY(d)).strength(0.3));
    ringG.style("display", "none");
  }
  sim.alpha(0.9).restart();
});

document.getElementById("zin").addEventListener("click", () => svg.transition().call(zoomBehavior.scaleBy, 1.3));
document.getElementById("zout").addEventListener("click", () => svg.transition().call(zoomBehavior.scaleBy, 1 / 1.3));
document.getElementById("zfit").addEventListener("click", () => svg.transition().call(zoomBehavior.transform, d3.zoomIdentity));

window.addEventListener("resize", () => {
  W = container.clientWidth; H = container.clientHeight;
  svg.attr("width", W).attr("height", H);
  if (radialMode) {
    precomputeAngles(); placeL0(); drawRingBackgrounds();
    sim.force("radial", d3.forceRadial(n => n.layer === 0 ? 0 : getRadii(n.layer).mid, W / 2, H / 2)
        .strength(n => n.layer === 0 ? 0 : (n.layer === 5 ? 0.25 : 0.9)));
    sim.force("angular", forceAngular());
    sim.force("l0", forceL0());
    initRadialPositions();
  } else {
    sim.force("x", d3.forceX(d => layerX(d.layer)).strength(0.92));
    sim.force("y", d3.forceY(d => categoryY(d)).strength(0.3));
  }
  sim.alpha(0.5).restart();
});

document.querySelectorAll(".legend-type-item").forEach(item => {
  item.addEventListener("click", () => {
    const types = item.dataset.types.split(",");
    const allActive = types.every(t => activeTypes.has(t));
    if (allActive) types.forEach(t => activeTypes.delete(t));
    else types.forEach(t => activeTypes.add(t));
    item.classList.toggle("inactive", !types.every(t => activeTypes.has(t)));
    applyFilters();
  });
});
document.querySelectorAll(".ring-legend").forEach(item => {
  item.addEventListener("click", () => selectLayer(+item.dataset.layer));
});

// ==== SIDE PANEL ====
const sidePanel = document.getElementById("side-panel");
document.getElementById("sp-close").addEventListener("click", () => clearSelection());
svg.on("click", () => clearSelection());

function closeSidePanel() { sidePanel.classList.remove("open"); }

function openSidePanel(d) {
  sidePanel.classList.add("open");
  document.getElementById("sp-name").textContent = d.name;
  document.getElementById("sp-cats").textContent = `${d.superCat} · ${d.category} · ${d.subCat}`;
  document.getElementById("sp-pop-fill").style.width = d.pop + "%";
  document.getElementById("sp-desc").textContent = d.desc;

  const conns = LINKS.filter(l => {
    if (l.sourceIsBubble || l.targetIsBubble) return false;
    return l.sourceRef === d.id || l.targetRef === d.id;
  });
  document.getElementById("sp-connections").innerHTML = conns.map(l => {
    const other = l.sourceRef === d.id ? l.targetRef : l.sourceRef;
    const dir = l.sourceRef === d.id ? "→" : "←";
    const col = EDGE_COLOR[l.type] || "#94A3B8";
    return `<div class="sp-conn-item" data-arrow-id="${l.arrowId}">
      <span class="sp-conn-dot" style="background:${col}"></span>
      <span class="sp-conn-text">
        <span>${dir} ${refLabel(other)}</span>
        <span class="sp-conn-name">${l.name}</span>
      </span>
      <span class="sp-conn-type">${l.type}</span>
    </div>`;
  }).join("") || '<div style="font-size:10px;color:#64748B">No direct connections.</div>';

  document.querySelectorAll(".sp-conn-item").forEach(el => {
    el.addEventListener("click", () => {
      const id = el.dataset.arrowId;
      const l = LINKS.find(x => x.arrowId === id);
      if (!l) return;
      document.querySelectorAll(".sp-conn-item").forEach(e => e.classList.remove("active"));
      el.classList.add("active");
      selectedArrowId = id;
      link.classed("selected-arrow", x => x.arrowId === id);
    });
  });

  const spLink = document.getElementById("sp-link");
  if (d.domain) { spLink.href = "https://" + d.domain; spLink.style.display = "block"; }
  else spLink.style.display = "none";

  document.getElementById("sp-linkedin-btn").onclick = () => {
    const tag = "#" + d.category.replace(/[\s&/]+/g, "");
    const blurb = `🚀 ${d.name}\n\n${d.desc}\n\n${tag} #AI #AITools #AILandscape2026`;
    navigator.clipboard.writeText(blurb).then(() => {
      const btn = document.getElementById("sp-linkedin-btn");
      btn.textContent = "Copied ✓";
      setTimeout(() => { btn.textContent = "Copy LinkedIn blurb"; }, 2000);
    });
  };
}

function openBubblePanel(bubId) {
  const grp = BUBBLE_GROUPS[bubId];
  if (!grp) return;
  sidePanel.classList.add("open");
  document.getElementById("sp-name").textContent = grp.label + " (bubble)";
  document.getElementById("sp-cats").textContent = `Layer ${grp.layer}: ${LAYER_NAMES[grp.layer]} · ${grp.memberIds.length} members`;
  document.getElementById("sp-pop-fill").style.width = "100%";
  document.getElementById("sp-desc").textContent = "Members: " + grp.memberIds.map(id => {
    const n = NODES.find(x => x.id === id); return n ? n.name : id;
  }).join(", ");

  const bubRef = `bub:${bubId}`;
  const conns = LINKS.filter(l => l.sourceRef === bubRef || l.targetRef === bubRef);
  document.getElementById("sp-connections").innerHTML = conns.map(l => {
    const other = l.sourceRef === bubRef ? l.targetRef : l.sourceRef;
    const dir = l.sourceRef === bubRef ? "→" : "←";
    const col = EDGE_COLOR[l.type] || "#94A3B8";
    const otherIsBub = l.sourceRef === bubRef ? l.targetIsBubble : l.sourceIsBubble;
    return `<div class="sp-conn-item" data-arrow-id="${l.arrowId}">
      <span class="sp-conn-dot" style="background:${col}"></span>
      <span class="sp-conn-text">
        <span>${dir} ${otherIsBub ? "📦 " : ""}${refLabel(other)}</span>
        <span class="sp-conn-name">${l.name}</span>
      </span>
      <span class="sp-conn-type">${l.type}</span>
    </div>`;
  }).join("") || '<div style="font-size:10px;color:#64748B">No bubble-level connections.</div>';

  document.querySelectorAll(".sp-conn-item").forEach(el => {
    el.addEventListener("click", () => {
      const id = el.dataset.arrowId;
      document.querySelectorAll(".sp-conn-item").forEach(e => e.classList.remove("active"));
      el.classList.add("active");
      selectedArrowId = id;
      link.classed("selected-arrow", x => x.arrowId === id);
    });
  });

  document.getElementById("sp-link").style.display = "none";
  document.getElementById("sp-linkedin-btn").onclick = () => {
    const blurb = `🚀 ${grp.label} — Layer ${grp.layer} bubble\n\n${grp.memberIds.length} tools in this category.\n\n#AILandscape2026`;
    navigator.clipboard.writeText(blurb);
  };
}

node.on("click", (ev, d) => { ev.stopPropagation(); selectNode(d); });

applyFilters();

} // end if(!IS_MOBILE)

// ==== MOBILE RENDERER ====
function renderMobile() {
  // Inject mobile DOM
  const app = document.createElement('div');
  app.id = 'm-app';
  app.classList.add('active');
  app.innerHTML = `
    <div id="m-header">
      <div id="m-title-row">
        <div id="m-title">AI Landscape <span>2026</span></div>
        <div id="m-sub" data-stat>${NODES.length} tools · 6 layers</div>
      </div>
      <input id="m-search" placeholder="Search tools, categories…" autocomplete="off"/>
      <div id="m-chips">
        <button class="m-chip active" data-cat="all">All</button>
        <button class="m-chip" data-cat="Hardware">Hardware</button>
        <button class="m-chip" data-cat="Infrastructure">Infra</button>
        <button class="m-chip" data-cat="Models">Models</button>
        <button class="m-chip" data-cat="Tools">Tools</button>
        <button class="m-chip" data-cat="Creative AI">Creative</button>
        <button class="m-chip" data-cat="Emerging">Emerging</button>
      </div>
    </div>
    <div id="m-scroll"></div>
    <div id="m-sheet"><div id="m-sheet-card"><button id="m-sheet-close">&times;</button><div id="m-sheet-body"></div></div></div>
  `;
  document.body.appendChild(app);

  const PERSONAS = new Set(["Developer","Enterprise","Creator","Consumer","Researcher"]);
  const SIM = NODES.filter(n => !PERSONAS.has(n.id));

  // Connection lookup (skip bubble refs)
  const connsByNode = {};
  LINKS_RAW.forEach(row => {
    const [s, t, type, w, name] = row;
    if (typeof s !== 'string' || typeof t !== 'string') return;
    if (s.startsWith('bub:') || t.startsWith('bub:')) return;
    (connsByNode[s] ||= []).push({ other: t, type, dir: '→', name });
    (connsByNode[t] ||= []).push({ other: s, type, dir: '←', name });
  });

  function mInitials(name) {
    const p = name.split(/[\s\-]+/).filter(Boolean);
    return p.length === 1 ? p[0].slice(0,2).toUpperCase() : (p[0][0] + p[1][0]).toUpperCase();
  }
  function logoHtml(n, sizeClass) {
    const url = n.imgUrl || (n.domain ? `https://www.google.com/s2/favicons?domain=${n.domain}&sz=128` : null);
    if (url) return `<div class="${sizeClass}"><img src="${url}" alt="" loading="lazy" onerror="this.parentNode.innerHTML='<span class=\\'m-init\\'>${mInitials(n.name)}</span>'"/></div>`;
    return `<div class="${sizeClass}"><span class="m-init">${mInitials(n.name)}</span></div>`;
  }

  let activeCat = 'all';
  let searchTerm = '';

  const scroll = document.getElementById('m-scroll');
  const stat = document.querySelector('#m-sub');

  function render() {
    scroll.innerHTML = '';
    let total = 0;
    for (let layer = 0; layer <= 5; layer++) {
      const layerNodes = SIM.filter(n => n.layer === layer);
      const filtered = layerNodes.filter(n => {
        if (activeCat !== 'all' && n.superCat !== activeCat) return false;
        if (searchTerm) {
          const t = searchTerm;
          if (!n.name.toLowerCase().includes(t) &&
              !n.category.toLowerCase().includes(t) &&
              !(n.subCat||'').toLowerCase().includes(t)) return false;
        }
        return true;
      }).sort((a,b) => b.pop - a.pop);
      if (!filtered.length) continue;
      total += filtered.length;

      const subCats = {};
      filtered.forEach(n => { (subCats[n.category] ||= []).push(n); });

      const color = LAYER_COLORS[layer];
      let html = `<section class="m-layer" style="--lc:${color}">
        <div class="m-layer-head">
          <div class="m-layer-bar"></div>
          <div class="m-layer-num">L${layer}</div>
          <div class="m-layer-name">${LAYER_NAMES[layer]}</div>
          <div class="m-layer-count">${filtered.length}</div>
        </div>`;
      Object.entries(subCats).forEach(([cat, nodes]) => {
        html += `<div class="m-cat">${cat}</div><div class="m-grid">`;
        nodes.forEach(n => {
          html += `<button class="m-card" data-id="${encodeURIComponent(n.id)}">
            ${logoHtml(n, 'm-logo-wrap')}
            <div class="m-name">${n.name}</div>
          </button>`;
        });
        html += `</div>`;
      });
      html += `</section>`;
      scroll.insertAdjacentHTML('beforeend', html);
    }

    if (!total) scroll.innerHTML = `<div class="m-empty">No matches.</div>`;
    stat.textContent = `${total} tools · 6 layers`;

    scroll.querySelectorAll('.m-card').forEach(el => {
      el.addEventListener('click', () => openSheet(decodeURIComponent(el.dataset.id)));
    });
  }

  function openSheet(id) {
    const n = NODES.find(x => x.id === id);
    if (!n) return;
    const cs = (connsByNode[id] || []).slice(0, 14);
    const body = document.getElementById('m-sheet-body');
    body.innerHTML = `
      <div class="m-sheet-top">
        ${logoHtml(n, 'm-sheet-logo')}
        <div>
          <div class="m-sheet-name">${n.name}</div>
          <div class="m-sheet-cat">${n.superCat} · ${n.category}${n.subCat ? ' · ' + n.subCat : ''}</div>
        </div>
      </div>
      <div class="m-sheet-pop">
        <div class="m-sheet-pop-lbl"><span>Popularity</span><b>${n.pop}</b></div>
        <div class="m-sheet-pop-bar"><span style="width:${n.pop}%"></span></div>
      </div>
      <div class="m-sheet-desc">${n.desc}</div>
      ${cs.length ? `<div class="m-sheet-conn-lbl">Connects to (${(connsByNode[id]||[]).length})</div>
        <div class="m-sheet-conns">${cs.map(c => {
          const oN = NODES.find(x => x.id === c.other);
          return `<span class="m-conn-pill">${c.dir} ${oN ? oN.name : c.other}<em>${c.type}</em></span>`;
        }).join('')}</div>` : ''}
      ${n.domain ? `<a class="m-sheet-link" href="https://${n.domain}" target="_blank" rel="noopener">Visit ${n.domain} →</a>` : ''}
    `;
    document.getElementById('m-sheet').classList.add('open');
  }

  document.getElementById('m-sheet-close').addEventListener('click', () => {
    document.getElementById('m-sheet').classList.remove('open');
  });
  document.getElementById('m-sheet').addEventListener('click', (e) => {
    if (e.target.id === 'm-sheet') document.getElementById('m-sheet').classList.remove('open');
  });
  document.querySelectorAll('.m-chip').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.m-chip').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      activeCat = b.dataset.cat;
      render();
      scroll.scrollTop = 0;
    });
  });
  document.getElementById('m-search').addEventListener('input', (e) => {
    searchTerm = e.target.value.toLowerCase().trim();
    render();
  });

  render();
}
</script>
</body>
</html>
