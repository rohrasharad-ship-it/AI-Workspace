<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<title>AI Landscape 2026 — Interactive AI Ecosystem Map</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes"/>
<meta name="description" content="156 tools, 310 connections, 6 layers from chip foundries to end-user apps. Explore how the AI stack connects."/>
<meta property="og:type" content="website"/>
<meta property="og:site_name" content="AI Landscape 2026"/>
<meta property="og:title" content="AI Landscape 2026 — Interactive AI Ecosystem Map"/>
<meta property="og:description" content="156 tools, 310 connections, 6 layers from chip foundries to end-user apps. Explore how the AI stack connects."/>
<meta property="og:url" content="https://ai-landscape-ten.vercel.app/"/>
<meta property="og:image" content="https://ai-landscape-ten.vercel.app/preview.png"/>
<meta property="og:image:width" content="1200"/>
<meta property="og:image:height" content="630"/>
<meta property="og:image:alt" content="AI Landscape 2026 radial map — 156 tools across six layers from foundries to applications"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="AI Landscape 2026 — Interactive AI Ecosystem Map"/>
<meta name="twitter:description" content="156 tools, 310 connections, 6 layers from chip foundries to end-user apps. Explore how the AI stack connects."/>
<meta name="twitter:image" content="https://ai-landscape-ten.vercel.app/preview.png"/>
<meta name="twitter:image:alt" content="AI Landscape 2026 radial map — 156 tools across six layers from foundries to applications"/>
<script src="https://d3js.org/d3.v7.min.js"></script>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; overflow:hidden; background:#0A0F1E; color:#E2E8F0; font-family:system-ui,-apple-system,sans-serif; }
#controls { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; align-items:center; gap:10px; padding:10px 14px; background:rgba(10,15,30,0.96); backdrop-filter:blur(10px); border-bottom:1px solid rgba(255,255,255,0.08); height:56px; flex-wrap:wrap;}
#title { font-size:14px; font-weight:700; color:#F8FAFC; white-space:nowrap; }
#title span { color:#38BDF8; }
#search { flex:0 1 180px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12); border-radius:6px; padding:6px 10px; color:#E2E8F0; font-size:12px; outline:none; }
.filter-btn { padding:5px 10px; border-radius:6px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.06); color:#CBD5E1; font-size:11px; cursor:pointer; white-space:nowrap; }
.filter-btn:hover { background:rgba(255,255,255,0.12); }
.filter-btn.active { background:rgba(56,189,248,0.2); border-color:#38BDF8; color:#F8FAFC; font-weight:600; }
#slider-wrap, #slider-wrap-link { display:flex; align-items:center; gap:8px; background:rgba(255,255,255,0.05); padding:5px 10px; border-radius:6px; border:1px solid rgba(255,255,255,0.1); }
#slider-wrap label, #slider-wrap-link label { font-size:11px; color:#94A3B8; white-space:nowrap; }
#pop-slider { width:130px; accent-color:#38BDF8; cursor:pointer; }
#pop-value { font-size:12px; font-weight:700; color:#38BDF8; min-width:28px; text-align:center; }
#stats { margin-left:auto; font-size:11px; color:#64748B; white-space:nowrap; }
#layout-toggle, #clear-btn { padding:5px 10px; border-radius:6px; border:1px solid rgba(255,255,255,0.15); background:rgba(168,85,247,0.15); color:#E0D4FF; font-size:11px; cursor:pointer; }
#layout-toggle:hover, #clear-btn:hover { background:rgba(168,85,247,0.3); }
#canvas-container { position:fixed; top:56px; left:0; right:0; bottom:0; overflow:hidden; }
#canvas { display:block; width:100%; height:100%; background:radial-gradient(ellipse at center, #0E1629 0%, #0A0F1E 100%); }
#tooltip { position:fixed; pointer-events:none; background:rgba(10,15,30,0.98); border:1px solid rgba(255,255,255,0.15); border-radius:8px; padding:10px 12px; max-width:320px; z-index:200; display:none; box-shadow:0 10px 30px rgba(0,0,0,0.6); }
#tooltip .tt-name { font-size:14px; font-weight:700; color:#F8FAFC; margin-bottom:3px; }
#tooltip .tt-cats { font-size:10px; color:#64748B; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.04em; }
#tooltip .tt-desc { font-size:11px; color:#CBD5E1; line-height:1.4; margin-bottom:6px; }
#tooltip .tt-meta { font-size:10px; color:#94A3B8; display:flex; gap:10px; }
#tooltip .tt-pop { color:#38BDF8; font-weight:700; }
#tooltip .tt-conn-name { font-size:12px; font-weight:700; color:#FBBF24; margin-bottom:4px; }
#tooltip .tt-conn-type { font-size:10px; color:#94A3B8; text-transform:uppercase; letter-spacing:0.05em; }
#legend { position:fixed; bottom:14px; left:14px; z-index:100; background:rgba(10,15,30,0.92); border:1px solid rgba(255,255,255,0.08); border-radius:8px; padding:10px 13px; max-width:230px; }
#legend h4 { font-size:9px; color:#64748B; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px; }
.legend-item { display:flex; align-items:center; gap:6px; margin-bottom:4px; font-size:10px; color:#CBD5E1; }
.legend-dot { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
.legend-line { width:18px; height:2px; flex-shrink:0; }
.ring-legend { cursor:pointer; padding:2px 4px; margin:-2px -4px; border-radius:3px; }
.ring-legend:hover { background:rgba(255,255,255,0.06); }
.link { fill:none; opacity:0.07; cursor:pointer; }
.link.highlight { opacity:0.9; }
.link.dim { opacity:0.02; }
.link.selected-arrow { opacity:1; stroke-width:3.5px !important; }
.bubble-label { text-shadow: 0 1px 4px #0A0F1E, 0 0 10px #0A0F1E; cursor:pointer; }
.bubble-hull { cursor:pointer; transition:fill-opacity 0.2s; }
.bubble-hull.bubble-dim { opacity:0.15; }
.bubble-hull.bubble-selected { fill-opacity:0.28 !important; stroke-width:3px !important; }
#side-panel { position:fixed; top:56px; right:-340px; width:320px; bottom:0; background:rgba(10,15,30,0.98); border-left:1px solid rgba(255,255,255,0.1); z-index:150; transition:right 0.25s cubic-bezier(.4,0,.2,1); overflow-y:auto; display:flex; flex-direction:column; }
#side-panel.open { right:0; }
#sp-header { display:flex; align-items:flex-start; justify-content:space-between; padding:16px 14px 12px; border-bottom:1px solid rgba(255,255,255,0.08); }
#sp-name { font-size:16px; font-weight:700; color:#F8FAFC; flex:1; line-height:1.3; }
#sp-close { background:none; border:none; color:#64748B; font-size:20px; cursor:pointer; padding:0; margin-left:8px; line-height:1; flex-shrink:0; }
#sp-close:hover { color:#E2E8F0; }
.sp-section { padding:11px 14px; border-bottom:1px solid rgba(255,255,255,0.05); }
.sp-label { font-size:9px; text-transform:uppercase; letter-spacing:0.08em; color:#64748B; margin-bottom:5px; }
#sp-cats { font-size:10px; color:#94A3B8; margin-bottom:6px; }
.sp-pop-bar { height:4px; background:rgba(255,255,255,0.08); border-radius:2px; }
#sp-pop-fill { display:block; height:100%; border-radius:2px; background:#38BDF8; transition:width 0.3s; }
#sp-desc { font-size:12px; color:#CBD5E1; line-height:1.55; }
.sp-conn-item { display:flex; align-items:center; gap:7px; font-size:11px; color:#CBD5E1; padding:4px 2px; border-radius:3px; cursor:pointer; }
.sp-conn-item:hover { background:rgba(255,255,255,0.05); }
.sp-conn-item.active { background:rgba(251,191,36,0.12); }
.sp-conn-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.sp-conn-type { font-size:9px; color:#64748B; margin-left:auto; }
.sp-conn-name { font-size:9px; color:#FBBF24; display:block; margin-top:1px; font-style:italic; }
.sp-conn-text { flex:1; display:flex; flex-direction:column; }
#sp-actions { padding:12px 14px; margin-top:auto; display:flex; flex-direction:column; gap:8px; }
#sp-link { display:block; padding:8px 12px; background:rgba(56,189,248,0.1); border:1px solid rgba(56,189,248,0.25); border-radius:6px; color:#38BDF8; font-size:12px; text-decoration:none; text-align:center; }
#sp-link:hover { background:rgba(56,189,248,0.2); }
#sp-linkedin-btn { padding:8px 12px; background:rgba(10,102,194,0.18); border:1px solid rgba(10,102,194,0.4); border-radius:6px; color:#93C5FD; font-size:12px; text-align:center; cursor:pointer; }
#sp-linkedin-btn:hover { background:rgba(10,102,194,0.3); }
.legend-type-item { cursor:pointer; border-radius:4px; padding:2px 5px; margin:-2px -5px; transition:opacity 0.15s; user-select:none; }
.legend-type-item:hover { background:rgba(255,255,255,0.07); }
.legend-type-item.inactive { opacity:0.3; }
.node { cursor:pointer; }
.node.dim { opacity:0.1; }
.node-circle { stroke-width:1.5px; }
.node-circle.highlight { stroke:#F8FAFC; stroke-width:2.5px; }
.label { font-size:8px; font-weight:600; pointer-events:none; text-anchor:middle; fill:#E2E8F0; }
.label.dim { opacity:0.15; }
.ring-label { font-weight:700; letter-spacing:0.1em; text-transform:uppercase; pointer-events:auto; fill-opacity:0.8; cursor:pointer; text-shadow: 0 1px 4px #0A0F1E, 0 0 10px #0A0F1E; }
.ring-label:hover { fill-opacity:1; }
.sector-label { font-weight:600; letter-spacing:0.04em; text-transform:uppercase; pointer-events:none; }
#zoom { position:fixed; bottom:14px; right:14px; z-index:100; display:flex; gap:4px; }
#zoom button { width:34px; height:34px; background:rgba(10,15,30,0.92); border:1px solid rgba(255,255,255,0.15); color:#CBD5E1; border-radius:6px; cursor:pointer; font-size:15px; }
#zoom button:hover { background:rgba(255,255,255,0.12); }
#hint { position:fixed; top:66px; left:50%; transform:translateX(-50%); font-size:10px; color:#64748B; z-index:50; pointer-events:none; background:rgba(10,15,30,0.7); padding:3px 10px; border-radius:4px; }

/* ===== MOBILE (separate DOM, rendered when IS_MOBILE) ===== */
#m-app { position:fixed; inset:0; display:none; flex-direction:column; background:#0A0F1E; color:#E2E8F0; overflow:hidden; z-index:300; }
#m-app.active { display:flex; }
#m-header { padding:14px 14px 10px; background:linear-gradient(180deg,#0E1629 0%,#0A0F1E 100%); border-bottom:1px solid rgba(255,255,255,0.08); flex-shrink:0; }
#m-title-row { display:flex; align-items:baseline; justify-content:space-between; }
#m-title { font-size:20px; font-weight:800; letter-spacing:-0.02em; }
#m-title span { color:#38BDF8; }
#m-sub { font-size:11px; color:#64748B; }
#m-search { width:100%; margin-top:10px; padding:10px 12px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); border-radius:8px; color:#E2E8F0; font-size:14px; outline:none; -webkit-appearance:none; }
#m-search::placeholder { color:#475569; }
#m-chips { display:flex; gap:6px; margin-top:10px; overflow-x:auto; -webkit-overflow-scrolling:touch; padding-bottom:2px; }
#m-chips::-webkit-scrollbar { display:none; }
.m-chip { flex-shrink:0; padding:7px 13px; border-radius:14px; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.04); color:#CBD5E1; font-size:12px; font-weight:600; cursor:pointer; }
.m-chip.active { background:rgba(56,189,248,0.18); border-color:#38BDF8; color:#F8FAFC; }
#m-scroll { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; padding-bottom:40px; }
.m-layer { padding:0 12px 18px; border-bottom:1px solid rgba(255,255,255,0.05); }
.m-layer-head { display:flex; align-items:center; gap:8px; padding:14px 4px 10px; position:sticky; top:0; background:#0A0F1E; z-index:2; border-bottom:1px solid rgba(255,255,255,0.04); }
.m-layer-bar { width:3px; height:18px; background:var(--lc); border-radius:2px; }
.m-layer-num { font-size:10px; font-weight:800; color:var(--lc); letter-spacing:0.1em; }
.m-layer-name { font-size:15px; font-weight:700; color:#F8FAFC; flex:1; }
.m-layer-count { font-size:11px; color:#64748B; background:rgba(255,255,255,0.05); padding:2px 8px; border-radius:10px; }
.m-cat { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#64748B; margin:12px 4px 6px; }
.m-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; }
.m-card { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:10px 4px 7px; display:flex; flex-direction:column; align-items:center; gap:5px; cursor:pointer; min-height:74px; transition:transform 0.1s, background 0.15s; }
.m-card:active { background:rgba(56,189,248,0.12); transform:scale(0.96); }
.m-logo-wrap { width:34px; height:34px; border-radius:8px; background:#fff; display:flex; align-items:center; justify-content:center; overflow:hidden; flex-shrink:0; }
.m-logo-wrap img { width:100%; height:100%; object-fit:cover; }
.m-init { color:#1E293B; font-weight:800; font-size:11px; }
.m-name { font-size:9.5px; line-height:1.2; color:#CBD5E1; text-align:center; word-wrap:break-word; max-width:100%; }
.m-empty { padding:50px 20px; text-align:center; color:#475569; font-size:13px; }
#m-sheet { position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:400; display:flex; align-items:flex-end; opacity:0; pointer-events:none; transition:opacity 0.2s; }
#m-sheet.open { opacity:1; pointer-events:auto; }
#m-sheet-card { width:100%; max-height:78vh; background:#0E1629; border-radius:18px 18px 0 0; padding:18px 18px 28px; overflow-y:auto; position:relative; transform:translateY(100%); transition:transform 0.25s cubic-bezier(.4,0,.2,1); }
#m-sheet.open #m-sheet-card { transform:translateY(0); }
#m-sheet-close { position:absolute; top:8px; right:10px; background:none; border:none; color:#64748B; font-size:30px; line-height:1; cursor:pointer; }
.m-sheet-top { display:flex; gap:12px; align-items:center; margin-bottom:14px; padding-right:32px; }
.m-sheet-logo { width:52px; height:52px; border-radius:12px; background:#fff; flex-shrink:0; display:flex; align-items:center; justify-content:center; overflow:hidden; }
.m-sheet-logo img { width:100%; height:100%; object-fit:cover; }
.m-sheet-name { font-size:19px; font-weight:800; color:#F8FAFC; line-height:1.2; }
.m-sheet-cat { font-size:11px; color:#64748B; margin-top:3px; }
.m-sheet-pop { margin-bottom:14px; }
.m-sheet-pop-lbl { font-size:10px; color:#94A3B8; margin-bottom:5px; display:flex; justify-content:space-between; }
.m-sheet-pop-lbl b { color:#38BDF8; }
.m-sheet-pop-bar { height:4px; background:rgba(255,255,255,0.08); border-radius:2px; overflow:hidden; }
.m-sheet-pop-bar span { display:block; height:100%; background:linear-gradient(90deg,#38BDF8,#A78BFA); }
.m-sheet-desc { font-size:13.5px; line-height:1.55; color:#CBD5E1; margin-bottom:14px; }
.m-sheet-conn-lbl { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#64748B; margin-bottom:8px; }
.m-sheet-conns { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:16px; }
.m-conn-pill { font-size:11px; padding:5px 9px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:10px; color:#CBD5E1; }
.m-conn-pill em { color:#94A3B8; font-style:normal; font-size:9px; margin-left:4px; text-transform:uppercase; letter-spacing:0.04em; }
.m-sheet-link { display:block; padding:11px 14px; background:rgba(56,189,248,0.12); border:1px solid rgba(56,189,248,0.3); border-radius:10px; color:#38BDF8; text-align:center; font-size:13px; font-weight:600; text-decoration:none; }
</style>
</head>
<body>

<div id="controls">
  <div id="title">AI Landscape <span>2026</span> v4</div>
  <input id="search" type="text" placeholder="Search..."/>
  <div id="slider-wrap">
    <label>Popularity &ge;</label>
    <input id="pop-slider" type="range" min="0" max="100" step="5" value="60"/>
    <span id="pop-value">60</span>
  </div>
  <div id="slider-wrap-link" class="slider-wrap-cls">
    <label>Link &ge;</label>
    <input id="link-slider" type="range" min="1" max="5" step="1" value="1"/>
    <span id="link-value" style="color:#A78BFA">1</span>
  </div>
  <button class="filter-btn active" data-cat="all">All</button>
  <button class="filter-btn" data-cat="Hardware">Hardware</button>
  <button class="filter-btn" data-cat="Models">Models</button>
  <button class="filter-btn" data-cat="Creative AI">Creative</button>
  <button class="filter-btn" data-cat="Tools">Tools</button>
  <button class="filter-btn" data-cat="Infrastructure">Infra</button>
  <button class="filter-btn" data-cat="Emerging">Emerging</button>
  <button id="layout-toggle">View: Radial</button>
  <button id="clear-btn">Clear Selection</button>
  <div id="stats"></div>
</div>

<div id="canvas-container">
  <svg id="canvas"></svg>
</div>
<div id="hint">Click node or bubble to focus · Click a ring name to isolate a layer · Click an arrow for connection detail</div>

<div id="tooltip"></div>

<div id="legend">
  <h4>Connection type <span style="color:#475569;font-weight:400">(click to toggle)</span></h4>
  <div class="legend-item legend-type-item" data-types="manufactures,powers"><div class="legend-line" style="background:#F59E0B"></div>manufactures / powers</div>
  <div class="legend-item legend-type-item" data-types="hosts,runs"><div class="legend-line" style="background:#8B5CF6"></div>hosts / runs</div>
  <div class="legend-item legend-type-item" data-types="built-on"><div class="legend-line" style="background:#06B6D4"></div>built-on</div>
  <div class="legend-item legend-type-item" data-types="integrates,routes,monitors,guards"><div class="legend-line" style="background:#94A3B8"></div>integrates / routes / guards</div>
  <h4 style="margin-top:8px">Rings (center → outer, click to isolate)</h4>
  <div class="legend-item ring-legend" data-layer="0"><div class="legend-dot" style="background:#B45309"></div>Foundry</div>
  <div class="legend-item ring-legend" data-layer="1"><div class="legend-dot" style="background:#F59E0B"></div>Chip Designers</div>
  <div class="legend-item ring-legend" data-layer="2"><div class="legend-dot" style="background:#06B6D4"></div>Cloud / Hubs</div>
  <div class="legend-item ring-legend" data-layer="3"><div class="legend-dot" style="background:#3B82F6"></div>Foundation Models</div>
  <div class="legend-item ring-legend" data-layer="4"><div class="legend-dot" style="background:#A855F7"></div>Frameworks &amp; Infra</div>
  <div class="legend-item ring-legend" data-layer="5"><div class="legend-dot" style="background:#10B981"></div>Applications</div>
</div>

<div id="zoom">
  <button id="zin" title="Zoom in">+</button>
  <button id="zout" title="Zoom out">&minus;</button>
  <button id="zfit" title="Fit">&#9633;</button>
</div>

<div id="side-panel">
  <div id="sp-header">
    <div id="sp-name"></div>
    <button id="sp-close">&times;</button>
  </div>
  <div class="sp-section">
    <div class="sp-label">Category</div>
    <div id="sp-cats"></div>
    <div class="sp-pop-bar"><span id="sp-pop-fill"></span></div>
  </div>
  <div class="sp-section">
    <div class="sp-label">About</div>
    <div id="sp-desc"></div>
  </div>
  <div class="sp-section" id="sp-conn-section">
    <div class="sp-label">Connections (click to view arrow & name)</div>
    <div id="sp-connections"></div>
  </div>
  <div id="sp-actions">
    <a id="sp-link" target="_blank" rel="noopener">Visit site &rarr;</a>
    <button id="sp-linkedin-btn">Copy LinkedIn blurb</button>
  </div>
</div>

<script>
// ==== DATA: NODES ====
const NODES = [
  // L0 Foundries
  {"id":"TSMC","name":"TSMC","superCat":"Hardware","category":"Foundries","subCat":"Leading Foundries","desc":"70% global foundry revenue share. 3nm in production, 2nm upcoming. $100B US investment (5 new fabs).","pop":100,"layer":0,"domain":"tsmc.com"},
  {"id":"Samsung Foundry","name":"Samsung Foundry","superCat":"Hardware","category":"Foundries","subCat":"Leading Foundries","desc":"World's #2 foundry. 2nm Gate-All-Around production 2025. Makes Exynos, Google Tensor, and third-party AI chips.","pop":70,"layer":0,"domain":"samsung.com"},
  {"id":"Intel Foundry","name":"Intel IFS","superCat":"Hardware","category":"Foundries","subCat":"US Foundries","desc":"Intel Foundry Services. 18A node live 2025. US government $8.5B CHIPS Act funding. Microsoft, Amazon as customers.","pop":55,"layer":0,"domain":"intel.com"},
  {"id":"SMIC","name":"SMIC","superCat":"Hardware","category":"Foundries","subCat":"Chinese Foundries","desc":"China's top foundry. 7nm without EUV, working on 5nm. Critical supplier for Huawei Ascend AI chips under US export controls.","pop":60,"layer":0,"domain":"smics.com","imgUrl":"https://logo.clearbit.com/smics.com"},

  // L1 Chip Designers
  {"id":"NVIDIA","name":"NVIDIA","superCat":"Hardware","category":"Chip Designers","subCat":"GPU Makers","desc":"Dominant AI GPU maker with ~90% market share. Blackwell Ultra (B300) shipping; acquired Groq for $20B.","pop":100,"layer":1,"domain":"nvidia.com"},
  {"id":"AMD","name":"AMD","superCat":"Hardware","category":"Chip Designers","subCat":"GPU Makers","desc":"Primary NVIDIA challenger. MI350/MI355X with 4x perf vs MI300X; MI400 full-rack solution planned.","pop":75,"layer":1,"domain":"amd.com"},
